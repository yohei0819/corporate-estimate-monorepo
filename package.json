{
  "name": "corporate-estimate-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:public-site & npm run dev:diagnosis-app",
    "dev:public-site": "npm run dev -w @corporate-estimate/public-site",
    "dev:diagnosis-app": "npm run dev -w @corporate-estimate/diagnosis-app",
    "build:shared": "npm run build -w @corporate-estimate/shared",
    "build:public-site": "npm run build -w @corporate-estimate/public-site",
    "build:diagnosis-app": "npm run build -w @corporate-estimate/diagnosis-app",
    "build": "npm run build:shared && npm run build:public-site && npm run build:diagnosis-app",
    "generate:ogp": "node scripts/generate-ogp.mjs",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p apps/diagnosis-app/tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,scss,css,md,vue}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,scss,css,md,vue}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && rm -rf .deploy && mkdir -p .deploy && cp -R apps/public-site/.output/public/ .deploy/ && mkdir -p .deploy/app && cp -R apps/diagnosis-app/out/ .deploy/app/ && touch .deploy/.nojekyll && npx gh-pages -d .deploy --dotfiles -m 'Deploy to GitHub Pages' && rm -rf .deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": "true",
  "workspaces": [
    "apps/public-site",
    "apps/diagnosis-app",
    "packages/shared"
  ],
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "canvas": "^3.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@next/swc-darwin-x64": "^16.1.7"
  }
}
