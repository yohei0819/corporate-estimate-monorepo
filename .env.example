# ============================================================
# Corporate Estimate Monorepo — 環境変数テンプレート
# ============================================================
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
#
# 各アプリ固有の環境変数は下記も参照:
#   apps/public-site/.env.example
#   apps/diagnosis-app/.env.example
# ============================================================

# ── public-site (Nuxt 3) ────────────────────────────────────
# 診断アプリのオリジン
NUXT_PUBLIC_DIAGNOSIS_APP_ORIGIN=http://localhost:3001

# Google Analytics 4 Measurement ID（任意）
NUXT_PUBLIC_GA_ID=

# ── diagnosis-app (Next.js) ─────────────────────────────────
# 公開サイトのオリジン
NEXT_PUBLIC_PUBLIC_SITE_ORIGIN=http://localhost:3000

# Google Analytics 4 Measurement ID（任意）
NEXT_PUBLIC_GA_ID=
